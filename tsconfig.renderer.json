{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "src/renderer.ts",
    "src/shared/**/*.ts",
    "src/tools/**/*.ts",
    "src/global.d.ts"
  ]
}
